{
  "name": "kitoma-accounts-app",
  "version": "1.0.0",
  "description": "Kitoma Secondary School Accounts Management System",
  "main": "electron.js",
  "author": "KATO ELVIS",
  "license": "ISC",

  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"npm run start-electron\"",
    "start-electron": "wait-on http://localhost:5173 && electron .",
    "build-frontend": "npm run build --prefix frontend",
    "build-backend": "python package_backend.py",
    "build": "npm run build-frontend && npm run build-backend && electron-builder"
  },

  "build": {
    "appId": "com.kitoma.accounts",
    "productName": "Kitoma Accounts",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "electron.js",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/backend.exe",
        "to": "backend.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}